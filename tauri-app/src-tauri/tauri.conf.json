{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "protoai",
  "version": "0.4.0",
  "identifier": "com.protoai.dev",
  "build": {
    "frontendDist": "../ui",
    "beforeDevCommand": "",
    "beforeBuildCommand": ""
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "title": "protoai",
        "width": 1280,
        "height": 900,
        "backgroundColor": "#0d0d0d",
        "devtools": true
      }
    ],
    "security": {
      "csp": null,
      "assetProtocol": {
        "enable": true,
        "scope": ["**"]
      }
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "externalBin": [
      "binaries/node"
    ],
    "resources": [
      "resources/server/**/*",
      "resources/python-embed/**/*"
    ],
    "createUpdaterArtifacts": true
  },
  "plugins": {
    "updater": {
      "active": true,
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDIwMkM0NjU3NTY4NDQ5QTgKUldTb1NZUldWMFlzSUdzQSs2cUYxVmhIYU41THBOczE5S2NUSFRvRXF4ZXo2aStmZzFRdGp1bGgK",
      "endpoints": [
        "https://github.com/trechurch/ProtoAI.exe/releases/latest/download/latest.json"
      ],
      "dialog": true,
      "windows": {
        "installerArgs": [],
        "installMode": "passive"
      }
    }
  }
}
